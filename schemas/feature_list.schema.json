{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feature_list.schema.json",
  "title": "Feature List",
  "description": "sprint 级 feature 全量清单,是 Hermes 的 Source of Truth。所有 feature 状态、phase、checkpoint 配置都在这里。",
  "type": "object",
  "required": ["version", "sprint", "tooling_locked", "features"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.2"
    },
    "sprint": {
      "type": "string",
      "description": "sprint id,如 sprint_20260421_1"
    },
    "pipeline_id": {
      "type": ["string", "null"],
      "description": "若基于已有管线实例化,记录管线 id;从零规划则为 null"
    },
    "pipeline_version": {
      "type": ["string", "null"],
      "description": "管线版本号,如 1.3"
    },
    "tooling_locked": {
      "type": "boolean",
      "description": "phase=0 完成且 approved 后置 true。false 时禁止任何 feature 进入 phase=2"
    },
    "updated_at": {"type": "string", "format": "date-time"},
    "updated_by": {"type": "string"},
    "features": {
      "type": "array",
      "items": {"$ref": "#/$defs/feature"}
    },
    "blocked": {
      "type": "array",
      "description": "被阻塞的 feature id 列表",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "feature": {
      "type": "object",
      "required": ["id", "name", "status", "phase", "next_phases", "acceptance", "depends_on", "checkpoints"],
      "properties": {
        "id": {"type": "string", "pattern": "^f[0-9]+(-[0-9]+)*$"},
        "name": {"type": "string"},
        "title": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["planning", "pending", "in_progress", "completed", "blocked", "cancelled", "waiting_human"]
        },
        "assignee": {"type": "string", "default": "claude-code"},
        "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
        "phase": {"type": "integer", "minimum": 1, "maximum": 4},
        "next_phases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phase", "action", "done"],
            "properties": {
              "phase": {"type": "integer", "minimum": 1, "maximum": 4},
              "action": {"type": "string", "enum": ["plan", "implement", "verify", "deliver"]},
              "done": {"type": "boolean"},
              "current": {"type": "boolean"}
            }
          }
        },
        "acceptance": {
          "type": "array",
          "minItems": 1,
          "description": "可验证的验收标准。模糊描述(如'质量好')被禁止,见 spec/guides/acceptance-writing.md",
          "items": {"type": "string"}
        },
        "verification_mode": {
          "type": "string",
          "enum": ["automated", "human", "hybrid"],
          "default": "hybrid",
          "description": "automated=Evaluator 跑测试 | human=只检查完整性 + 必须签字 | hybrid=自动+抽查"
        },
        "depends_on": {
          "type": "array",
          "items": {"type": "string"}
        },
        "parent_id": {"type": ["string", "null"]},
        "children": {
          "type": "array",
          "items": {"type": "string"}
        },
        "branch": {"type": ["string", "null"]},
        "commit": {"type": ["string", "null"]},
        "pr_url": {"type": ["string", "null"]},
        "created_at": {"type": "string", "format": "date-time"},
        "completed_at": {"type": ["string", "null"], "format": "date-time"},
        "sprint_id": {"type": "string"},
        "checkpoints": {
          "type": "array",
          "items": {"$ref": "checkpoint.schema.json"}
        }
      }
    }
  }
}
